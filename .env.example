# API Config
PROJECT_NAME="LinkedIn AI Agent"
API_V1_STR="/api/v1"

# Database (Async PostgreSQL - Supabase or self-hosted)
# For Supabase: postgresql+psycopg_async://postgres:[password]@[project-ref].supabase.co:5432/postgres
# For local: postgresql+psycopg_async://postgres:password@localhost:5432/linkedin_agent
DATABASE_URL=postgresql+psycopg_async://postgres:password@localhost:5432/linkedin_agent

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langsmith_api_key"
LANGCHAIN_PROJECT="linkedin-content-agent"

# LLM Providers
OPENAI_API_KEY="your_openai_api_key"
